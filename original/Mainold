' --- Helpers ---

Private Function FindMostRecentFile(ByVal folderPath As String, ByVal pattern As String) As String
    Dim fso As Object, fldr As Object, f As Object
    Dim mostRecent As Date, resultPath As String
   
    On Error GoTo ExitPoint
    Set fso = CreateObject("Scripting.FileSystemObject")
    Set fldr = fso.GetFolder(folderPath)
   
    mostRecent = #1/1/1900#
    resultPath = ""
   
    For Each f In fldr.Files
        If (fso.GetFileName(f.Path) Like pattern) Then
            If f.DateLastModified > mostRecent Then
                mostRecent = f.DateLastModified
                resultPath = f.Path
            End If
        End If
    Next f
   
ExitPoint:
    FindMostRecentFile = resultPath
End Function

Private Function FindHeaderColumn(ByVal ws As Worksheet, ByVal headerText As String) As Long
    Dim lastCol As Long, c As Long
    lastCol = ws.Cells(1, ws.Columns.Count).End(xlToLeft).Column
    For c = 1 To lastCol
        If StrComp(Trim$(CStr(ws.Cells(1, c).Value)), headerText, vbTextCompare) = 0 Then
            FindHeaderColumn = c
            Exit Function
        End If
    Next c
    FindHeaderColumn = 0
End Function

Private Function DetectSourceSheet(ByVal wb As Workbook, ByVal headerText As String) As Worksheet
    Dim sh As Worksheet, colIdx As Long
    For Each sh In wb.Worksheets
        colIdx = FindHeaderColumn(sh, headerText)
        If colIdx > 0 Then
            Set DetectSourceSheet = sh
            Exit Function
        End If
    Next sh
    Set DetectSourceSheet = Nothing
End Function

Private Function ExtractAfterLastBackslash(ByVal s As String) As String
    Dim p As Long
    p = InStrRev(s, "\")
    If p > 0 Then
        ExtractAfterLastBackslash = Trim$(Mid$(s, p + 1))
    Else
        ExtractAfterLastBackslash = Trim$(s)
    End If
End Function

Private Function EnglishMonthAbbrev(m As Integer) As String
    Select Case m
        Case 1: EnglishMonthAbbrev = "Jan"
        Case 2: EnglishMonthAbbrev = "Feb"
        Case 3: EnglishMonthAbbrev = "Mar"
        Case 4: EnglishMonthAbbrev = "Apr"
        Case 5: EnglishMonthAbbrev = "May"
        Case 6: EnglishMonthAbbrev = "Jun"
        Case 7: EnglishMonthAbbrev = "Jul"
        Case 8: EnglishMonthAbbrev = "Aug"
        Case 9: EnglishMonthAbbrev = "Sep"
        Case 10: EnglishMonthAbbrev = "Oct"
        Case 11: EnglishMonthAbbrev = "Nov"
        Case 12: EnglishMonthAbbrev = "Dec"
        Case Else: EnglishMonthAbbrev = Format(Date, "mmm")
    End Select
End Function

Private Function EnsureUniquePath(ByVal folderPath2 As String, ByVal fileName As String) As String
    Dim fso As Object
    Dim baseName As String, ext As String
    Dim tryPath As String
    Dim n As Long
   
    Set fso = CreateObject("Scripting.FileSystemObject")
    baseName = Left$(fileName, InStrRev(fileName, ".") - 1)
    ext = Mid$(fileName, InStrRev(fileName, "."))
   
    tryPath = folderPath2
    If Right$(tryPath, 1) <> "\" Then tryPath = tryPath & "\"
    tryPath = tryPath & fileName
   
    n = 1
    Do While fso.FileExists(tryPath)
        tryPath = folderPath2
        If Right$(tryPath, 1) <> "\" Then tryPath = tryPath & "\"
        tryPath = tryPath & baseName & " (" & n & ")" & ext
        n = n + 1
    Loop
   
    EnsureUniquePath = tryPath
End Function



